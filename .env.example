# Supabase (https://supabase.com 대시보드 → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 — API Route에서 Riot/매칭 RPC 호출에 사용
# ⚠️ NEXT_PUBLIC_ 붙이면 안 됩니다. 브라우저에 노출되면 DB 전체가 위험해집니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Riot API (https://developer.riotgames.com)
# Personal Key: 계정 조회(Riot ID 연동) — 24시간마다 갱신
# ⚠️ Valorant 전적(match API)은 Production API Key 승인 후에만 동작합니다
RIOT_API_KEY=your-riot-api-key-here
RIOT_API_REGION=asia

# Valorant 전적 API shard (한국/아시아 = ap)
VALORANT_SHARD=ap

# Discord OAuth — Supabase Dashboard → Authentication → Providers → Discord
# Client ID/Secret은 .env가 아니라 Supabase 대시보드에만 입력합니다.

# ─────────────────────────────────────────────
# Vercel 배포 시 (Dashboard → Settings → Environment Variables)
# Production + Preview 환경 모두 아래 6개 추가:
#
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   RIOT_API_KEY
#   RIOT_API_REGION
#   VALORANT_SHARD
#
# Supabase → Authentication → URL Configuration:
#   Site URL: https://your-app.vercel.app
#   Redirect URLs:
#     https://your-app.vercel.app/**
#     http://localhost:3000/**
#
# 배포 후 확인: https://your-app.vercel.app/api/health → {"ok":true}
