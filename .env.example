# Supabase (https://supabase.com 대시보드 → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 서버 전용 — API Route에서 Riot/매칭 RPC 호출에 사용
# ⚠️ NEXT_PUBLIC_ 붙이면 안 됩니다. 브라우저에 노출되면 DB 전체가 위험해집니다.
# (비유: 집 열쇠를 현관 유리에 붙여 두는 것과 같음)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Riot Production API Key (https://developer.riotgames.com)
# ⚠️ NEXT_PUBLIC_ 금지 — 키가 브라우저/GitHub에 노출되면 남이 네 쿼터로 API를 긁어갑니다.
# Personal Key는 24시간 만료 + Valorant 전적 API 불가. Production Key를 쓰세요.
RIOT_API_KEY=your-riot-production-api-key-here
RIOT_API_REGION=asia

# Valorant 전적 API shard
# 한국 서버 = kr, 아시아(APAC) = ap
# 비워두면 active-shard API로 자동 감지 후 kr → ap 순으로 시도합니다.
VALORANT_SHARD=kr

# Discord OAuth — Supabase Dashboard → Authentication → Providers → Discord
# Client ID/Secret은 .env가 아니라 Supabase 대시보드에만 입력합니다.

# ─────────────────────────────────────────────
# Vercel 배포 시 (Dashboard → Settings → Environment Variables)
# Production + Preview 환경 모두 아래 6개 추가:
#
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   RIOT_API_KEY          ← Production Key (Preview도 같은 키 또는 별도 키)
#   RIOT_API_REGION
#   VALORANT_SHARD
#
# Supabase → Authentication → URL Configuration:
#   Site URL: https://your-app.vercel.app
#   Redirect URLs:
#     https://your-app.vercel.app/**
#     http://localhost:3000/**
#
# 배포 후 확인: https://your-app.vercel.app/api/health → {"ok":true}
# 로컬 키 스모크 테스트: node scripts/check-riot-key.mjs
#   verdict: PRODUCTION_KEY_LIKELY_OK 이면 전적 API 사용 가능
